{
  "info": {
    "name": "Jira Clone Backend",
    "description": "API collection for the Jira Clone multi-tenant backend. Start by registering a tenant or using the seeded tenants, then login to get tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantSlug",
      "value": "acme-corp",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns 200 OK if the server is running and connected to PostgreSQL."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.tokens.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.tokens.refreshToken);",
                  "  pm.collectionVariables.set('tenantSlug', res.data.tenant.slug);",
                  "  console.log('Tenant slug:', res.data.tenant.slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"My Startup\",\n  \"adminName\": \"John Doe\",\n  \"adminEmail\": \"john@mystartup.com\",\n  \"adminPassword\": \"password123\",\n  \"timezone\": \"America/New_York\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tenants/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tenants", "register"]
            },
            "description": "Creates a new tenant (organisation) and its first admin user (OWNER role). Automatically sets accessToken and refreshToken in collection variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Tokens saved. Role:', res.data.user.role);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"Password123!\",\n  \"tenantSlug\": \"acme-corp\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email, password, and tenantSlug. Returns access token (15min) + refresh token (7d). Auto-saves both tokens to collection variables.\n\nSeeded tenants:\n- alice@acme.com / Password123! / acme-corp\n- bob@beta.com / Password123! / beta-startup"
          },
          "response": []
        },
        {
          "name": "Get Current User (/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the currently logged-in user along with their tenant info. Tenant-scoped — a user from Tenant A cannot see Tenant B's data."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Tokens rotated successfully');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Issues a new access token + refresh token pair. The old refresh token is invalidated in the DB (rotation). Auto-saves new tokens to collection variables."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', '');",
                  "  pm.collectionVariables.set('refreshToken', '');",
                  "  console.log('Logged out — tokens cleared');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Revokes the refresh token in the DB. The access token expires naturally after 15 minutes. Clears both tokens from collection variables."
          },
          "response": []
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"wrongpassword\",\n  \"tenantSlug\": \"acme-corp\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Should return 401 Invalid credentials."
          },
          "response": []
        },
        {
          "name": "Login — Wrong Tenant (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@acme.com\",\n  \"password\": \"Password123!\",\n  \"tenantSlug\": \"beta-startup\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Alice belongs to acme-corp. Trying to login under beta-startup should return 401 — tenant isolation working."
          },
          "response": []
        },
        {
          "name": "/me — No Token (expect 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Should return 401 Missing or invalid authorization header."
          },
          "response": []
        },
        {
          "name": "Refresh — Used Token (expect 401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"paste-an-already-used-or-logged-out-refresh-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "After logout or a previous refresh, the old token is revoked. Should return 401."
          },
          "response": []
        }
      ]
    }
  ]
}
